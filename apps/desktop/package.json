{
  "name": "sandcastle-desktop",
  "private": true,
  "version": "0.0.0",
  "author": "Sandcastle contributors",
  "type": "module",
  "description": "Sandcastle Desktop: an Electron-supervised local AI company runtime and control plane. Not shipped with the npm package.",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm:dev:electron\"",
    "dev:electron": "tsc -p tsconfig.main.json && node scripts/start-dev-electron.mjs",
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.main.json",
    "dist": "npm run dist:unpacked",
    "dist:unpacked": "npm run build && electron-builder --dir",
    "dist:windows": "npm run build && electron-builder --win nsis --x64",
    "test": "tsx --test \"tests/**/*.test.ts\" \"main/**/*.test.ts\" \"runtime/**/*.test.ts\" \"preload/**/*.test.ts\" \"renderer/**/*.test.tsx\"",
    "test:electron-smoke": "electron scripts/electron-runtime-smoke.mjs",
    "test:packaged-app-smoke": "node scripts/run-packaged-app-smoke.mjs",
    "verify:windows-package": "node scripts/verify-windows-package.mjs",
    "test:runtime-capacity": "tsx scripts/runtime-capacity-smoke.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "acp": "tsx runtime/acpEntry.ts",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "build": {
    "appId": "dev.sandcastle.desktop",
    "productName": "Sandcastle",
    "files": [
      "dist-electron/**",
      "!dist-electron/**/*.test.js",
      "!dist-electron/**/*.test.js.map",
      "dist/**",
      "assets/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/sandcastle-icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/sandcastle-icon.png",
      "artifactName": "${productName}-${version}-windows-${arch}-setup.${ext}"
    }
  }
}
